PORT=8080
DATABASE_URL=postgres://databr:databr@localhost:5432/databr
REDIS_URL=redis://localhost:6379

# x402 — on-chain payments via Base network (USDC)
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS

# Testnet (sem CDP_API_KEY necessário — Bazaar indexa via facilitator.x402.rs)
X402_NETWORK=base-sepolia
X402_FACILITATOR_URL=https://facilitator.x402.rs

# Mainnet — Bazaar indexa automaticamente via CDP na primeira tx paga
# Descomente as linhas abaixo e comente as duas acima para produção:
# X402_NETWORK=base
# X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# CDP_API_KEY=sua_chave_cdp   # gratuito em https://portal.cdp.coinbase.com (1000 tx/mês)

CDP_API_KEY=
# Necessário apenas para facilitador mainnet (1000 tx/mês grátis, depois $0.001/tx)

# Fontes que exigem chave de API
TRANSPARENCIA_API_KEY=
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV...
MINHARECEITA_URL=https://minhareceita.org
BASE_URL=https://databr.api.br

# IBAMA sidecar Python (Fase 9, opcional agora)
IBAMA_SIDECAR_URL=http://localhost:9901
